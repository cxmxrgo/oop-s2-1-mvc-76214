@model library.MVC.Models.BookIndexViewModel

@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search title or author" />
    </div>
    <div class="col-md-3">
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            @foreach (var category in Model.Categories)
            {
                <option value="@category" selected="@(Model.Category == category)">@category</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="availability" class="form-select">
            <option value="All" selected="@(Model.Availability == "All")">All</option>
            <option value="Available" selected="@(Model.Availability == "Available")">Available</option>
            <option value="OnLoan" selected="@(Model.Availability == "OnLoan")">On loan</option>
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-success">Create Book</a>
    </p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Books)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Isbn</td>
            <td>@item.Category</td>
            <td>@(item.IsAvailable ? "Available" : "On loan")</td>
            <td>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <text> | </text>
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
